#!/bin/sh
set -eu

ACTION="${1:-}"
PATH_VALUE="${2:-}"
shift 2 2>/dev/null || true

if [ -z "$ACTION" ] || [ -z "$PATH_VALUE" ]; then
  echo "Usage: brainbar-trace <action> <path> [--agent name] [--reason text] [--session-id id] [--project name] [--source source] [--node-id id] [--status status]" >&2
  exit 64
fi

python3 - "$ACTION" "$PATH_VALUE" "$@" <<'PY'
import datetime
import json
import os
import pathlib
import subprocess
import sys

MAX_BYTES = 5 * 1024 * 1024
MAX_LINES = 10000
MAX_AGE_SECONDS = 7 * 24 * 60 * 60

action = sys.argv[1]
path_value = sys.argv[2]
args = sys.argv[3:]
allowed = {
    "read", "write", "create", "delete", "focus", "open",
    "graph_refresh", "closeout", "decision",
}
if action not in allowed:
    print(f"Unsupported action: {action}", file=sys.stderr)
    sys.exit(64)

mapping = {
    "--agent": "agent",
    "--reason": "reason",
    "--session-id": "session_id",
    "--project": "project",
    "--source": "source",
    "--node-id": "node_id",
    "--status": "status",
}

def explicit_agent(arguments):
    for position, argument in enumerate(arguments):
        if argument == "--agent" and position + 1 < len(arguments):
            return arguments[position + 1]
    return None

def command_name(pid):
    try:
        return subprocess.check_output(
            ["ps", "-p", str(pid), "-o", "comm="],
            text=True,
            stderr=subprocess.DEVNULL,
        ).strip()
    except Exception:
        return ""

def parent_pid(pid):
    try:
        value = subprocess.check_output(
            ["ps", "-p", str(pid), "-o", "ppid="],
            text=True,
            stderr=subprocess.DEVNULL,
        ).strip()
        return int(value) if value else 0
    except Exception:
        return 0

def inferred_agent():
    env_agent = os.environ.get("BRAINBAR_AGENT_NAME", "").strip()
    if env_agent:
        return env_agent
    pid = os.getppid()
    seen = set()
    for _ in range(12):
        if pid <= 1 or pid in seen:
            break
        seen.add(pid)
        name = command_name(pid).lower()
        if "claude" in name:
            return "claude"
        if "codex" in name:
            return "codex"
        pid = parent_pid(pid)
    return "codex"

fields = {
    "version": 1,
    "agent": explicit_agent(args) or inferred_agent(),
    "action": action,
    "path": path_value,
    "timestamp": datetime.datetime.now(datetime.timezone.utc).isoformat(timespec="milliseconds").replace("+00:00", "Z"),
}
index = 0
while index < len(args):
    key = args[index]
    if key not in mapping or index + 1 >= len(args):
        print(f"Unsupported argument: {key}", file=sys.stderr)
        sys.exit(64)
    fields[mapping[key]] = args[index + 1]
    index += 2

log_path = pathlib.Path.home() / "Library" / "Application Support" / "BrainBar" / "agent-events.jsonl"
log_path.parent.mkdir(parents=True, exist_ok=True)
with log_path.open("a", encoding="utf-8") as handle:
    handle.write(json.dumps(fields, ensure_ascii=False, sort_keys=True, separators=(",", ":")) + "\n")

try:
    if log_path.stat().st_size > MAX_BYTES:
        cutoff = datetime.datetime.now(datetime.timezone.utc) - datetime.timedelta(seconds=MAX_AGE_SECONDS)
        retained = []
        with log_path.open("r", encoding="utf-8") as handle:
            for line in handle:
                line = line.strip()
                if not line:
                    continue
                try:
                    payload = json.loads(line)
                    timestamp = payload.get("timestamp", "")
                    if timestamp.endswith("Z"):
                        timestamp = timestamp[:-1] + "+00:00"
                    parsed_at = datetime.datetime.fromisoformat(timestamp)
                    if parsed_at.tzinfo is None:
                        parsed_at = parsed_at.replace(tzinfo=datetime.timezone.utc)
                except Exception:
                    continue
                if parsed_at >= cutoff:
                    retained.append((parsed_at, line))
        retained.sort(key=lambda item: (item[0], item[1]))
        retained = retained[-MAX_LINES:]
        with log_path.open("w", encoding="utf-8") as handle:
            for _, line in retained:
                handle.write(line + "\n")
except Exception:
    pass
print(str(log_path))
PY
